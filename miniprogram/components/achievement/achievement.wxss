/* components/achievement/achievement.wxss */

.achievement-container {
  display: inline-block;
  position: relative;
}

/* 成就徽章 */
.achievement-badge {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #ffffff, #f0f0f0);
  box-shadow: 4rpx 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.achievement-badge:active {
  transform: scale(0.95);
}

/* 等级样式 */
.level-bronze {
  border: 3rpx solid #CD7F32;
}

.level-silver {
  border: 3rpx solid #C0C0C0;
}

.level-gold {
  border: 3rpx solid #FFD700;
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.3);
}

.level-diamond {
  border: 3rpx solid #B9F2FF;
  box-shadow: 0 0 30rpx rgba(185, 242, 255, 0.5);
  animation: diamond-glow 2s ease-in-out infinite;
}

.level-king {
  border: 3rpx solid #FF6B6B;
  box-shadow: 0 0 40rpx rgba(255, 107, 107, 0.6);
  animation: king-glow 1.5s ease-in-out infinite;
}

/* 徽章图标 */
.badge-icon {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.icon-emoji {
  font-size: 56rpx;
  filter: drop-shadow(2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2));
}

/* 光晕效果 */
.glow-effect {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100rpx;
  height: 100rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.8) 0%, transparent 70%);
  animation: glow-pulse 2s ease-in-out infinite;
  z-index: -1;
}

/* 等级标识 */
.badge-level {
  margin-top: 4rpx;
}

.level-text {
  font-size: 20rpx;
  font-weight: bold;
  color: #666;
}

/* 进度条 */
.badge-progress {
  width: 100%;
  padding: 0 12rpx;
  margin-top: 8rpx;
}

.progress-bar {
  width: 100%;
  height: 6rpx;
  background: #e0e0e0;
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);
  border-radius: 3rpx;
  transition: width 0.5s ease;
}

.progress-text {
  display: block;
  font-size: 18rpx;
  color: #999;
  text-align: center;
  margin-top: 4rpx;
}

/* NEW标识 */
.badge-new {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.4);
}

.new-text {
  font-size: 16rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 成就信息 */
.achievement-info {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  opacity: 0;
  max-height: 0;
  overflow: hidden;
  transition: all 0.3s ease;
}

.achievement-info.expanded {
  opacity: 1;
  max-height: 500rpx;
}

.info-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.info-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.info-time {
  display: block;
  font-size: 22rpx;
  color: #999;
}

/* 解锁动画 */
.unlock-animation {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  animation: fade-in 0.3s ease;
}

.animation-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: bounce-in 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.animation-badge {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  animation: rotate-scale 1s ease;
}

.animation-icon {
  font-size: 120rpx;
}

.animation-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFD700;
  margin-bottom: 16rpx;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.8);
  animation: title-glow 1.5s ease-in-out infinite;
}

.animation-name {
  font-size: 32rpx;
  color: #ffffff;
  text-align: center;
}

/* 动画关键帧 */
@keyframes glow-pulse {
  0%, 100% {
    opacity: 0.6;
    transform: translate(-50%, -50%) scale(1);
  }
  50% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.1);
  }
}

@keyframes diamond-glow {
  0%, 100% {
    box-shadow: 0 0 30rpx rgba(185, 242, 255, 0.5);
  }
  50% {
    box-shadow: 0 0 50rpx rgba(185, 242, 255, 0.8);
  }
}

@keyframes king-glow {
  0%, 100% {
    box-shadow: 0 0 40rpx rgba(255, 107, 107, 0.6);
  }
  50% {
    box-shadow: 0 0 60rpx rgba(255, 107, 107, 0.9);
  }
}

@keyframes fade-in {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes bounce-in {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
  70% {
    transform: scale(0.9);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes rotate-scale {
  0% {
    transform: rotate(-180deg) scale(0);
  }
  100% {
    transform: rotate(0deg) scale(1);
  }
}

@keyframes title-glow {
  0%, 100% {
    text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.8);
  }
  50% {
    text-shadow: 0 0 40rpx rgba(255, 215, 0, 1);
  }
}
