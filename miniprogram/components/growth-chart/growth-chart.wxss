/* components/growth-chart/growth-chart.wxss */

.growth-chart-container {
  padding: 30rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

/* 图表标题 */
.chart-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.chart-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.chart-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* ECharts 容器 */
ec-canvas {
  width: 100%;
  height: 500rpx;
  margin-bottom: 20rpx;
}

/* 图例 */
.chart-legend {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
}

.legend-name {
  font-size: 24rpx;
  color: #666666;
}

/* 数据提示 */
.chart-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #92400e;
}
