/* pages/player/player.wxss */

.player-container {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* 顶部标题栏 */
.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
  font-weight: 300;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-placeholder {
  width: 60rpx;
}

/* 进度条 */
.progress-bar {
  height: 4rpx;
  background: #e5e5e5;
  position: relative;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  transition: width 0.3s ease;
}

/* 内容区域 */
.content-area {
  flex: 1;
  height: 0;
}

/* 场景容器 */
.scene-slide,
.scene-quiz {
  padding: 24rpx;
}

/* 幻灯片卡片 */
.slide-card,
.quiz-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 场景标签 */
.scene-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.scene-tag.quiz-tag {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.tag-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

/* 场景标题 */
.scene-title-section {
  margin-bottom: 24rpx;
}

.scene-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.3;
  margin-bottom: 12rpx;
}

.scene-desc {
  display: block;
  font-size: 28rpx;
  color: #999;
  line-height: 1.5;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin-bottom: 32rpx;
}

/* 幻灯片内容 */
.slide-body {
  margin-bottom: 32rpx;
}

/* 备注区域 */
.remark-box {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.remark-label {
  display: block;
  font-size: 24rpx;
  color: #667eea;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.remark-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 知识点 */
.keywords-box {
  background: #fff7ed;
  border-radius: 16rpx;
  padding: 24rpx;
}

.keyword-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.keyword-item:last-child {
  margin-bottom: 0;
}

.keyword-dot {
  color: #f97316;
  margin-right: 8rpx;
  font-size: 20rpx;
  margin-top: 4rpx;
}

.keyword-text {
  font-size: 28rpx;
  color: #9a3412;
  line-height: 1.6;
}

/* 测验列表 */
.quiz-list {
  margin-bottom: 24rpx;
}

.quiz-question {
  margin-bottom: 48rpx;
}

.quiz-question:last-child {
  margin-bottom: 0;
}

/* 问题 */
.question-box {
  display: flex;
  margin-bottom: 20rpx;
}

.question-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.question-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
  padding-top: 8rpx;
}

/* 选项组 */
.options-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 选项 */
.quiz-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.option-selected {
  background: #e8ecff;
  border-color: #667eea;
}

.option-correct {
  background: #ecfdf5;
  border-color: #10b981;
}

.option-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #fff;
  border: 2rpx solid #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  position: relative;
}

.option-selected .option-circle,
.option-correct .option-circle {
  border-color: #667eea;
  background: #667eea;
}

.option-correct .option-circle {
  border-color: #10b981;
  background: #10b981;
}

.option-letter {
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
}

.option-selected .option-letter,
.option-correct .option-letter {
  color: #fff;
}

.option-check {
  position: absolute;
  font-size: 28rpx;
  color: #fff;
}

.option-label {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

/* 答案反馈 */
.answer-tip {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.tip-text {
  font-size: 28rpx;
  font-weight: 500;
}

.tip-correct {
  color: #10b981;
}

.tip-wrong {
  color: #ef4444;
}

/* 提交按钮区域 */
.quiz-submit-area {
  margin-top: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.submit-btn::after {
  border: none;
}

/* 完成提示 */
.quiz-done-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.done-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.done-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #10b981;
}

/* 底部占位 */
.bottom-spacer {
  height: 180rpx;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
}

.nav-btn-w {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  transition: all 0.2s ease;
}

.nav-btn-w::after {
  border: none;
}

.nav-disabled {
  opacity: 0.4;
}

.nav-icon {
  font-size: 36rpx;
  color: #333;
}

.nav-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin: 0 4rpx;
}

/* 中间进度 */
.nav-center {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.progress-dots {
  display: flex;
  gap: 6rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #e5e5e5;
}

.dot-active {
  background: #667eea;
}

/* 完成弹窗 */
.complete-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 560rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.modal-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-bottom: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #667eea;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
  margin: 0 48rpx;
}

.modal-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.modal-btn::after {
  border: none;
}
