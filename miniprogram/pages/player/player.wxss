/* pages/player/player.wxss */

.container-no-padding {
  min-height: 100vh;
  background: var(--bg-primary);
}

/* 视频播放区域 */
.video-wrapper {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%; /* 16:9 比例 */
  background: #000;
  overflow: hidden;
}

.video-player {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* 播放遮罩 */
.video-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0) 100%);
  display: flex;
  align-items: flex-end;
  padding: 48rpx 32rpx;
}

.overlay-content {
  width: 100%;
}

.overlay-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-white);
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.overlay-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

/* 播放按钮 */
.play-button-wrapper {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.play-button {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s ease;
}

.play-button:active {
  transform: scale(0.9);
}

.play-icon {
  font-size: 48rpx;
  color: var(--primary-color);
  margin-left: 6rpx;
}

/* 场景导航 */
.scenes-section {
  padding: 32rpx;
  padding-bottom: 16rpx;
}

.scenes-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.scenes-count {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 8rpx 16rpx;
  background: var(--bg-secondary);
  border-radius: 20rpx;
}

.scenes-scroll {
  white-space: nowrap;
}

.scenes-list {
  display: inline-flex;
  gap: 12rpx;
}

.scene-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: var(--card-background);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  min-width: 280rpx;
}

.scene-item.active {
  background: var(--primary-gradient);
  border-color: var(--primary-light);
}

.scene-item.completed {
  background: rgba(16, 185, 129, 0.05);
  border-color: var(--success-color);
}

.scene-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-secondary);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.scene-item.active .scene-number {
  background: rgba(255, 255, 255, 0.2);
  color: var(--text-white);
}

.scene-item.completed .scene-number {
  background: var(--success-color);
  color: var(--text-white);
}

.scene-content {
  flex: 1;
}

.scene-title {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scene-item.active .scene-title {
  color: var(--text-white);
}

.scene-duration {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.scene-item.active .scene-duration {
  color: rgba(255, 255, 255, 0.7);
}

.scene-status {
  font-size: 28rpx;
  color: var(--primary-color);
}

.scene-item.active .scene-status {
  color: var(--text-white);
}

.scene-item.completed .scene-status {
  color: var(--success-color);
}

/* 当前场景内容 */
.scene-content-section {
  padding: 0 32rpx 16rpx;
}

.content-card {
  background: var(--card-background);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: var(--card-shadow);
}

.scene-header {
  margin-bottom: 24rpx;
}

.scene-main-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  display: block;
}

.scene-badges {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

/* 场景文本 */
.scene-text {
  margin-bottom: 24rpx;
}

.text-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--text-primary);
}

/* 知识点标签 */
.knowledge-points {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.kp-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: var(--bg-secondary);
  border-radius: 20rpx;
}

.kp-icon {
  font-size: 22rpx;
}

.kp-text {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 500;
}

/* 课程信息 */
.course-info-section {
  padding: 0 32rpx 16rpx;
}

.info-card {
  background: var(--card-background);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: var(--card-shadow);
}

.info-header {
  margin-bottom: 24rpx;
}

.info-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* 操作按钮 */
.actions-section {
  padding: 32rpx;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}

.action-btn.primary {
  background: var(--primary-gradient);
  color: var(--text-white);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.action-btn.primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.action-btn.disabled {
  background: var(--bg-tertiary);
  color: var(--text-tertiary);
  box-shadow: none;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 32rpx;
}

/* 安全区域 */
.safe-area-bottom {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
}
