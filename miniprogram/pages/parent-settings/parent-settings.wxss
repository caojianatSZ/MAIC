/* pages/parent-settings/parent-settings.wxss */
.container {
  min-height: 100vh;
  background: #f9fafb;
  padding-bottom: 40rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.nav-back {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #333333;
}

.back-text {
  font-size: 28rpx;
  color: #333333;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.nav-placeholder {
  width: 120rpx;
}

/* 区块 */
.section {
  margin: 30rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.section-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 绑定卡片 */
.bind-button {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 8rpx 16rpx rgba(102, 126, 234, 0.3);
}

.bind-button:active {
  transform: scale(0.98);
}

.button-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.button-icon {
  font-size: 40rpx;
}

.button-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
}

.bind-tip {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 20rpx;
}

/* 已绑定卡片 */
.bound-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border-radius: 16rpx;
}

.bound-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.bound-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
}

.bound-details {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bound-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.bound-relation {
  font-size: 24rpx;
  color: #666666;
}

.unbind-button {
  padding: 16rpx 32rpx;
  background: #ffffff;
  border: 2rpx solid #ef4444;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #ef4444;
}

/* 通知列表 */
.notification-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.notification-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: #f9fafb;
  border-radius: 16rpx;
}

.item-info {
  flex: 1;
}

.item-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.item-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 通知预览 */
.preview-card {
  padding: 30rpx;
  background: #f9fafb;
  border-radius: 16rpx;
  border-left: 8rpx solid #6366F1;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.preview-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
}

.preview-time {
  font-size: 22rpx;
  color: #999999;
}

.preview-content {
  margin-bottom: 16rpx;
}

.preview-label {
  display: block;
  font-size: 22rpx;
  color: #6366F1;
  margin-bottom: 8rpx;
}

.preview-text {
  display: block;
  font-size: 26rpx;
  color: #333333;
  line-height: 1.6;
}

.preview-footer {
  display: flex;
  gap: 30rpx;
}

.preview-detail {
  font-size: 22rpx;
  color: #666666;
}

/* 使用说明 */
.instruction-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.instruction-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.instruction-number {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  color: #ffffff;
  flex-shrink: 0;
}

.instruction-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  padding-top: 8rpx;
}
