/* pages/checkin/checkin.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 40rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
}

.nav-back {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #ffffff;
}

.back-text {
  font-size: 28rpx;
  color: #ffffff;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.nav-placeholder {
  width: 120rpx;
}

/* 日历卡片 */
.calendar-card {
  margin: 30rpx;
  padding: 40rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.calendar-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.calendar-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.calendar-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 日历网格 */
.calendar-grid {
  margin-bottom: 40rpx;
}

.weekday-header {
  display: flex;
  margin-bottom: 20rpx;
}

.weekday-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #666666;
  font-weight: bold;
}

.days-container {
  display: flex;
  flex-wrap: wrap;
}

.day-item {
  width: 14.28%;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 10rpx;
}

.day-number {
  font-size: 28rpx;
  color: #333333;
}

.day-item.today .day-number {
  font-weight: bold;
  color: #6366F1;
}

.day-item.checked-in {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
}

.day-item.checked-in .day-number {
  color: #ffffff;
}

.checkin-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 24rpx;
  height: 24rpx;
  background: #10b981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-icon {
  font-size: 16rpx;
  color: #ffffff;
}

/* 打卡统计 */
.checkin-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  border-radius: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #6366F1;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e5e7eb;
}

/* 打卡按钮 */
.checkin-action {
  margin: 30rpx;
  text-align: center;
}

.checkin-button {
  width: 100%;
  height: 120rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
}

.checkin-button:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.checkin-button.checked {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.4);
}

.button-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.button-icon {
  font-size: 48rpx;
}

.button-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.checkin-tip {
  display: block;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.checkin-tip.success {
  color: #10b981;
  font-weight: bold;
}

/* 成就预览 */
.achievements-preview {
  margin: 30rpx;
  padding: 30rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.preview-header {
  margin-bottom: 24rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.achievements-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.achievement-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.achievement-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.achievement-info {
  flex: 1;
}

.achievement-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.achievement-progress {
  display: block;
  font-size: 24rpx;
  color: #666666;
}

.achievement-status {
  padding: 8rpx 20rpx;
  background: #e5e7eb;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666666;
}

.achievement-status.unlocked {
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  color: #ffffff;
}

/* 打卡提醒 */
.reminder-section {
  margin: 30rpx;
  padding: 30rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.reminder-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.reminder-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.reminder-desc {
  font-size: 24rpx;
  color: #999999;
}
