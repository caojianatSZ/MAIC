<!--pages/login/login.wxml-->
<view class="container">
  <!-- 关闭按钮 -->
  <view class="close-btn" bindtap="goBack">
    <text class="close-icon">✕</text>
  </view>

  <!-- 顶部标题区 -->
  <view class="header">
    <view class="logo-container">
      <image src="/images/hz-logo-clean.png" class="logo-image" mode="aspectFit" />
    </view>
    <text class="title">湖南弘知教育</text>
    <text class="subtitle">AI 驱动的智能学习平台</text>
  </view>

  <!-- 登录方式选择 -->
  <view class="login-methods">
    <!-- 微信登录 -->
    <button class="login-btn wechat-login" bindtap="wechatLogin">
      <view class="btn-icon">💬</view>
      <text class="btn-text">微信快捷登录</text>
    </button>
  </view>

  <!-- 用户协议 -->
  <view class="agreement">
    <checkbox-group bindchange="onAgreementChange">
      <label class="agreement-label">
        <checkbox value="agree" checked="{{agreed}}" color="#6366F1" />
        <text class="agreement-text">
          我已阅读并同意
          <text class="link">《用户协议》</text>
          和
          <text class="link">《隐私政策》</text>
        </text>
      </label>
    </checkbox-group>
  </view>

  <!-- 登录说明 -->
  <view class="login-tips">
    <text class="tips-title">登录后你可以：</text>
    <view class="tips-list">
      <text class="tips-item">✓ 保存学习进度</text>
      <text class="tips-item">✓ 获取个性化学习路径</text>
      <text class="tips-item">✓ 查看错题本</text>
      <text class="tips-item">✓ 解锁完整课程</text>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-spacer"></view>
</view>
