/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  position: relative;
}

/* 关闭按钮 */
.close-btn {
  position: absolute;
  top: 48rpx;
  right: 32rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.close-icon {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 300;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-top: 120rpx;
  margin-bottom: 80rpx;
}

.logo {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.slogan {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 登录方式 */
.login-methods {
  margin-bottom: 48rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: none;
  position: relative;
  overflow: hidden;
}

.login-btn::after {
  border: none;
}

.wechat-login {
  background: #FFFFFF;
  color: #1F2937;
}

.phone-login {
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.btn-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
}

/* 用户协议 */
.agreement {
  margin-bottom: 48rpx;
  padding: 0 16rpx;
}

.agreement-label {
  display: flex;
  align-items: flex-start;
}

.agreement-text {
  flex: 1;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
  margin-left: 12rpx;
}

.link {
  color: #FFFFFF;
  text-decoration: underline;
}

/* 登录说明 */
.login-tips {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 24rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tips-item {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 动画 */
.login-btn:active {
  transform: scale(0.98);
}

.wechat-login:active {
  background: #F3F4F6;
}

.phone-login:active {
  background: rgba(255, 255, 255, 0.3);
}
