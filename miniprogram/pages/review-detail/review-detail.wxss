/* pages/review-detail/review-detail.wxss */
/* 错题详情页样式 */

.container {
  min-height: 100vh;
  background: #F9FAFB;
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 题目卡片 */
.question-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.subject-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.subject-badge.subject-math {
  background: #EEF2FF;
  color: #6366F1;
}

.subject-badge.subject-physics {
  background: #FEE2E2;
  color: #DC2626;
}

.subject-badge.subject-chemistry {
  background: #FEF3C7;
  color: #D97706;
}

.subject-badge.subject-english {
  background: #ECFDF5;
  color: #059669;
}

.subject-badge.subject-chinese {
  background: #F3E8FF;
  color: #9333EA;
}

.meta-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

.question-content {
  padding: 20rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.question-text {
  font-size: 28rpx;
  color: #1F2937;
  line-height: 1.6;
}

/* 答案区域 */
.answer-section {
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.answer-section.student {
  background: #FEF2F2;
  border: 1rpx solid #FECACA;
}

.answer-section.correct {
  background: #ECFDF5;
  border: 1rpx solid #A7F3D0;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.section-icon {
  font-size: 28rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #374151;
}

.answer-value {
  display: block;
  font-size: 28rpx;
  color: #1F2937;
  line-height: 1.5;
  padding-left: 36rpx;
}

.answer-value.correct {
  color: #059669;
}

.answer-value.wrong {
  color: #DC2626;
}

/* 标准答案解析容器 */
.solution-container {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.solution-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  transition: all 0.3s;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.header-icon {
  font-size: 32rpx;
}

.header-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.expand-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.expand-icon {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  transition: transform 0.3s;
}

.expand-icon.expanded {
  transform: rotate(180deg);
}

/* 解析内容 */
.solution-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease-out;
}

.solution-content.expanded {
  max-height: 3000rpx;
}

.solution-section {
  border-bottom: 1rpx solid #F3F4F6;
}

.solution-section:last-child {
  border-bottom: none;
}

.solution-section-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 12rpx;
  cursor: pointer;
}

.section-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.section-dot.exam {
  background: #F59E0B;
}

.section-dot.method {
  background: #3B82F6;
}

.section-dot.analysis {
  background: #8B5CF6;
}

.section-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #1F2937;
}

.section-toggle {
  font-size: 24rpx;
  color: #9CA3AF;
  transition: transform 0.3s;
}

.section-toggle.expanded {
  transform: rotate(180deg);
}

.section-content {
  max-height: 0;
  overflow: hidden;
  padding: 0 24rpx;
  transition: all 0.3s ease-out;
}

.section-content.expanded {
  max-height: 1000rpx;
  padding-bottom: 20rpx;
}

.section-text {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
  white-space: pre-wrap;
}

/* 最终答案 */
.final-answer {
  display: flex;
  flex-direction: column;
  padding: 20rpx 24rpx;
  background: #ECFDF5;
  margin: 16rpx 24rpx 24rpx;
  border-radius: 16rpx;
}

.final-answer-label {
  font-size: 24rpx;
  color: #059669;
  margin-bottom: 8rpx;
}

.final-answer-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #047857;
}

/* 加载中 */
.solution-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #E5E7EB;
  border-top-color: #6366F1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 空状态 */
.solution-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 知识点卡片 */
.knowledge-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.title-icon {
  font-size: 32rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
}

.knowledge-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.knowledge-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #F3F4F6;
  border-radius: 24rpx;
  border: 1rpx solid #E5E7EB;
}

.knowledge-tag.level-weak {
  background: #FEF2F2;
  border-color: #FECACA;
}

.knowledge-tag.level-partial {
  background: #FFFBEB;
  border-color: #FDE68A;
}

.knowledge-tag.level-mastered {
  background: #ECFDF5;
  border-color: #A7F3D0;
}

.tag-text {
  font-size: 26rpx;
  color: #374151;
}

.tag-level {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.5);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  transition: all 0.3s;
}

.action-btn.secondary {
  background: #fff;
  color: #374151;
  border: 2rpx solid #E5E7EB;
}

.action-btn.primary {
  background: #10B981;
  color: #fff;
}

.action-btn.mastered {
  background: #ECFDF5;
  color: #059669;
  border: 2rpx solid #A7F3D0;
}

.btn-icon {
  font-size: 32rpx;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #6B7280;
}

.stat-divider {
  width: 1rpx;
  background: #E5E7EB;
}
