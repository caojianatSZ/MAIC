/* pages/privacy/privacy.wxss */
.container {
  min-height: 100vh;
  background: #F9FAFB;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  background: #FFFFFF;
  border-bottom: 2rpx solid #E5E7EB;
}

.nav-back {
  display: flex;
  align-items: center;
}

.back-icon {
  font-size: 36rpx;
  color: #1F2937;
  margin-right: 8rpx;
}

.back-text {
  font-size: 28rpx;
  color: #1F2937;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.nav-placeholder {
  width: 120rpx;
}

/* 内容滚动区域 */
.content-scroll {
  flex: 1;
  height: 100vh;
}

/* 内容区域 */
.content {
  padding: 32rpx;
}

/* 头部 */
.header {
  text-align: center;
  padding: 48rpx 0 40rpx;
  border-bottom: 2rpx solid #E5E7EB;
  margin-bottom: 32rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1F2937;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.update-time {
  display: block;
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 区块 */
.section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.section-text {
  display: block;
  font-size: 28rpx;
  color: #4B5563;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.section-text:last-child {
  margin-bottom: 0;
}

/* 子区块 */
.sub-section {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.sub-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 12rpx;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.list-dot {
  font-size: 28rpx;
  color: #6366F1;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.list-text {
  flex: 1;
  font-size: 28rpx;
  color: #4B5563;
  line-height: 1.8;
}

/* 联系信息 */
.contact-info {
  display: block;
  margin-top: 16rpx;
  padding: 20rpx;
  background: #EEF2FF;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #4F46E5;
  text-align: center;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #9CA3AF;
}
