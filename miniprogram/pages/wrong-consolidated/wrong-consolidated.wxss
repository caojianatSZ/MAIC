/* pages/wrong-consolidated/wrong-consolidated.wxss */
/* 错题合并视图样式 */

.container {
  min-height: 100vh;
  background: #F9FAFB;
  padding-bottom: 40rpx;
}

/* 页面头部 */
.page-header {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  padding: 40rpx 32rpx 32rpx;
  color: #fff;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
}

/* 掌握度概览 */
.mastery-overview {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin: -32rpx 24rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.12);
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.overview-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.overview-value.weak {
  color: #EF4444;
}

.overview-value.partial {
  color: #F59E0B;
}

.overview-value.mastered {
  color: #10B981;
}

.overview-label {
  font-size: 24rpx;
  color: #6B7280;
}

.overview-divider {
  width: 1rpx;
  height: 60rpx;
  background: #E5E7EB;
}

/* 科目筛选 */
.subject-filter {
  padding: 0 24rpx 24rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  gap: 16rpx;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 40rpx;
  border: 2rpx solid #E5E7EB;
  transition: all 0.3s;
}

.filter-item.active {
  background: #6366F1;
  border-color: #6366F1;
}

.filter-text {
  font-size: 28rpx;
  color: #374151;
  white-space: nowrap;
}

.filter-item.active .filter-text {
  color: #fff;
}

.filter-count {
  font-size: 22rpx;
  color: #9CA3AF;
  background: #F3F4F6;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.filter-item.active .filter-count {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E5E7EB;
  border-top-color: #6366F1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #6B7280;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1F2937;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #6B7280;
  text-align: center;
}

/* 知识点分组列表 */
.consolidated-list {
  padding: 0 24rpx;
}

.knowledge-section {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

/* 知识点头部 */
.knowledge-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #fff;
  transition: background 0.3s;
}

.knowledge-info {
  flex: 1;
  padding-right: 16rpx;
}

.knowledge-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.knowledge-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.mastery-level-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.mastery-level-badge.level-weak {
  background: #FEF2F2;
  color: #DC2626;
}

.mastery-level-badge.level-partial {
  background: #FFFBEB;
  color: #D97706;
}

.mastery-level-badge.level-mastered {
  background: #ECFDF5;
  color: #059669;
}

.knowledge-stats {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #6B7280;
}

.stat-divider {
  color: #D1D5DB;
}

.expand-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #9CA3AF;
  transition: transform 0.3s;
}

.expand-icon.expanded {
  transform: rotate(90deg);
}

/* 错题列表 */
.wrong-questions-list {
  padding: 0 24rpx 24rpx;
  background: #F9FAFB;
}

.wrong-question-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid #E5E7EB;
}

.question-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.question-id {
  font-size: 24rpx;
  color: #9CA3AF;
}

.question-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wrong-count {
  font-size: 24rpx;
  color: #EF4444;
  background: #FEF2F2;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.review-count {
  font-size: 24rpx;
  color: #6366F1;
  background: #EEF2FF;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.question-content {
  display: block;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.question-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.add-time {
  font-size: 24rpx;
  color: #9CA3AF;
}

.action-buttons {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #F3F4F6;
  color: #374151;
}

.action-btn.primary {
  background: #6366F1;
  color: #fff;
}

/* 更多题目提示 */
.more-questions-tip {
  text-align: center;
  padding: 16rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 知识点底部操作 */
.knowledge-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.action-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #E5E7EB;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.action-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #1F2937;
  margin-bottom: 4rpx;
}

.action-desc {
  font-size: 22rpx;
  color: #6B7280;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  padding: 32rpx;
}

.footer-tip .tip-text {
  font-size: 24rpx;
  color: #9CA3AF;
}
