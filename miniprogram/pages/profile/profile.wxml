<!--pages/profile/profile.wxml-->
<view class="container-no-padding">
  <!-- 顶部用户信息卡片 -->
  <view class="profile-header">
    <view class="header-bg"></view>

    <view class="user-card-wrapper">
      <view class="user-card">
        <view class="user-avatar-section" bindtap="onChangeAvatar">
          <image
            class="user-avatar"
            src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}"
            mode="aspectFill"
          />
          <view class="avatar-badge">
            <text class="badge-icon">📷</text>
          </view>
        </view>

        <view class="user-info-section">
          <text class="user-name">{{userInfo.nickName || '点击登录'}}</text>
          <view class="user-tags">
            <view class="user-tag">
              <text class="tag-icon">⭐</text>
              <text class="tag-text">VIP用户</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 快速统计 -->
    <view class="quick-stats">
      <view class="stat-item" bindtap="onViewHistory">
        <text class="stat-value">{{stats.totalCount}}</text>
        <text class="stat-label">总辅导</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onViewToday">
        <text class="stat-value">{{stats.todayCount}}</text>
        <text class="stat-label">今日</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onViewWrong">
        <text class="stat-value">{{stats.wrongCount || 0}}</text>
        <text class="stat-label">错题</text>
      </view>
    </view>
  </view>

  <!-- 学生画像内容 -->
  <view class="content-wrapper">
    <!-- 知识掌握雷达图 -->
    <view class="card">
      <view class="card-header">
        <text class="section-title">📊 知识掌握雷达图</text>
      </view>
      <view class="radar-chart-container">
        <view class="radar-placeholder">
          <text class="placeholder-text">雷达图组件即将上线</text>
          <text class="placeholder-sub">将展示知识掌握度可视化</text>
        </view>
      </view>
    </view>

    <!-- 我的成就 -->
    <view class="card">
      <view class="card-header">
        <text class="section-title">🏆 我的成就</text>
        <view class="more-btn" bindtap="onViewMoreAchievements">
          <text class="more-text">查看全部</text>
          <text class="more-arrow">›</text>
        </view>
      </view>

      <view class="achievements-grid" wx:if="{{achievements.length > 0}}">
        <achievement
          wx:for="{{achievements.slice(0, 6)}}"
          wx:key="id"
          achievementId="{{item.id}}"
          level="{{item.level}}"
          name="{{item.name}}"
          description="{{item.description}}"
          progress="{{item.progress}}"
          unlocked="{{item.unlocked}}"
          unlockedAt="{{item.unlockedAt}}"
          showLevel="{{true}}"
          showInfo="{{false}}"
          bind:tap="onAchievementTap"
        ></achievement>
      </view>

      <view class="empty-achievements" wx:else>
        <text class="empty-icon">🏆</text>
        <text class="empty-text">开始学习，解锁你的第一个成就！</text>
      </view>
    </view>

    <!-- 学习标签 -->
    <view class="card">
      <view class="card-header">
        <text class="section-title">🎯 学习分析</text>
      </view>

      <view class="tags-section">
        <view class="tag-group" wx:if="{{strongPoints.length > 0}}">
          <text class="tag-group-title">强项</text>
          <view class="tags-list">
            <view class="tag-item strong" wx:for="{{strongPoints}}" wx:key="*this" wx:for-item="tag">
              <text class="tag-text">{{tag}}</text>
            </view>
          </view>
        </view>

        <view class="tag-group" wx:if="{{weakPoints.length > 0}}">
          <text class="tag-group-title">待提升</text>
          <view class="tags-list">
            <view class="tag-item weak" wx:for="{{weakPoints}}" wx:key="*this" wx:for-item="tag">
              <text class="tag-text">{{tag}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 学习统计 -->
    <view class="card" wx:if="{{studentProfile && studentProfile.studyStats}}">
      <view class="card-header">
        <text class="section-title">📈 学习统计</text>
      </view>

      <view class="stats-grid">
        <view class="stat-box">
          <text class="stat-value">{{studentProfile.studyStats.totalStudyTime || 0}}</text>
          <text class="stat-label">学习时长(分钟)</text>
        </view>
        <view class="stat-box">
          <text class="stat-value">{{studentProfile.studyStats.questionsCompleted || 0}}</text>
          <text class="stat-label">完成题目</text>
        </view>
        <view class="stat-box">
          <text class="stat-value">{{studentProfile.studyStats.lessonsLearned || 0}}</text>
          <text class="stat-label">学习课程</text>
        </view>
        <view class="stat-box">
          <text class="stat-value">{{studentProfile.studyStats.currentStreak || 0}}</text>
          <text class="stat-label">连续打卡(天)</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 主内容区（原有功能菜单） -->
  <view class="content-wrapper">
    <!-- 学习档案 -->
    <view class="card">
      <view class="card-header">
        <text class="section-title">📚 学习档案</text>
        <view class="edit-btn" bindtap="onEditProfile">
          <text class="edit-text">编辑</text>
          <text class="edit-arrow">›</text>
        </view>
      </view>

      <view class="profile-info" wx:if="{{profile.grade || profile.subjects}}">
        <view class="info-row" wx:if="{{profile.grade}}">
          <text class="info-label">年级</text>
          <text class="info-value">{{profile.grade}}</text>
        </view>
        <view class="info-row" wx:if="{{profile.subjects && profile.subjects.length > 0}}">
          <text class="info-label">科目</text>
          <view class="subjects-tags">
            <view class="subject-tag" wx:for="{{profile.subjects}}" wx:key="*this">
              <text>{{item}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="empty-profile" wx:else>
        <text class="empty-text">还未设置学习档案</text>
        <view class="setup-btn" bindtap="onEditProfile">
          <text>立即设置</text>
        </view>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="card">
      <view class="menu-list">
        <view class="menu-item" bindtap="onViewHistory" hover-class="menu-item-hover">
          <view class="menu-icon">📖</view>
          <view class="menu-content">
            <text class="menu-title">学习记录</text>
            <text class="menu-desc">查看所有辅导记录</text>
          </view>
          <view class="menu-arrow">
            <text class="arrow-icon">›</text>
          </view>
        </view>

        <view class="menu-divider"></view>

        <view class="menu-item" bindtap="onWrongQuestions" hover-class="menu-item-hover">
          <view class="menu-icon">❌</view>
          <view class="menu-content">
            <text class="menu-title">错题本</text>
            <text class="menu-desc">巩固错题，举一反三</text>
          </view>
          <view class="menu-badge">
            <text class="badge-count">{{stats.wrongCount || 0}}</text>
          </view>
          <view class="menu-arrow">
            <text class="arrow-icon">›</text>
          </view>
        </view>

        <view class="menu-divider"></view>

        <view class="menu-item" bindtap="onAchievements" hover-class="menu-item-hover">
          <view class="menu-icon">🏆</view>
          <view class="menu-content">
            <text class="menu-title">学习成就</text>
            <text class="menu-desc">查看你的学习进度</text>
          </view>
          <view class="menu-arrow">
            <text class="arrow-icon">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 其他功能 -->
    <view class="card">
      <view class="menu-list">
        <view class="menu-item" bindtap="onAbout" hover-class="menu-item-hover">
          <view class="menu-icon">ℹ️</view>
          <text class="menu-text">关于我们</text>
          <text class="menu-arrow">›</text>
        </view>

        <view class="menu-divider"></view>

        <view class="menu-item" bindtap="onFeedback" hover-class="menu-item-hover">
          <view class="menu-icon">💬</view>
          <text class="menu-text">意见反馈</text>
          <text class="menu-arrow">›</text>
        </view>

        <view class="menu-divider"></view>

        <view class="menu-item" bindtap="onHelp" hover-class="menu-item-hover">
          <view class="menu-icon">❓</view>
          <text class="menu-text">使用帮助</text>
          <text class="menu-arrow">›</text>
        </view>

        <view class="menu-divider"></view>

        <view class="menu-item" bindtap="onSettings" hover-class="menu-item-hover">
          <view class="menu-icon">⚙️</view>
          <text class="menu-text">设置</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 底部版本信息 -->
    <view class="footer">
      <text class="footer-text">作业辅导助手 v1.0.0</text>
    </view>
  </view>
</view>
