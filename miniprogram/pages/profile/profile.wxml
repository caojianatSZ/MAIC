<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-avatar">
      <image
        class="avatar-img"
        src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}"
        mode="aspectFill"
      />
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || '未登录'}}</text>
      <text class="user-status">免费用户</text>
    </view>
  </view>

  <!-- 使用统计 -->
  <view class="card">
    <view class="card-title">
      <text class="title-text">使用统计</text>
    </view>
    <view class="card-body">
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-value">{{stats.totalCount}}</text>
          <text class="stat-label">总使用次数</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{stats.todayCount}}</text>
          <text class="stat-label">今日使用</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="card">
    <view class="card-title">
      <text class="title-text">历史记录</text>
    </view>
    <view class="card-body">
      <view class="history-list" wx:if="{{historyList.length > 0}}">
        <view
          class="history-item"
          wx:for="{{historyList}}"
          wx:key="id"
          bindtap="onViewHistory"
          data-id="{{item.id}}"
        >
          <view class="history-header">
            <text class="history-question">{{item.question}}</text>
            <text class="history-time">{{item.createdAt}}</text>
          </view>
          <view class="history-footer">
            <text class="history-status">已完成</text>
          </view>
        </view>
      </view>
      <view class="empty-state" wx:else>
        <text class="empty-text">暂无历史记录</text>
        <text class="empty-hint">去首页提交作业吧</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="card">
    <view class="card-body">
      <view class="menu-list">
        <view class="menu-item" bindtap="onAbout">
          <text class="menu-text">关于我们</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onFeedback">
          <text class="menu-text">意见反馈</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onHelp">
          <text class="menu-text">使用帮助</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>
  </view>
</view>
