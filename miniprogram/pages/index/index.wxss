/* pages/index/index.wxss */

.header {
  text-align: center;
  padding: 48rpx 0;
  margin-bottom: 32rpx;
}

.header .title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-bottom: 16rpx;
}

.header .subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.card {
  background-color: var(--card-background);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  margin-bottom: 24rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.card-body {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-camera {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
  background-color: var(--background-color);
  border: 2rpx dashed var(--primary-color);
  border-radius: 16rpx;
  color: var(--primary-color);
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.btn-camera:active {
  opacity: 0.8;
}

.btn-icon {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.hint {
  font-size: 24rpx;
  color: var(--text-placeholder);
  text-align: center;
}

.textarea-input {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background-color: var(--background-color);
  border-radius: 8rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.char-count {
  align-self: flex-end;
  font-size: 24rpx;
  color: var(--text-placeholder);
  margin-top: 8rpx;
}

.submit-section {
  margin-top: 48rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: var(--primary-color);
  color: #FFFFFF;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  border: none;
}

.btn-primary.active {
  opacity: 1;
}

.btn-primary.disabled {
  opacity: 0.5;
}

.btn-primary:active {
  opacity: 0.8;
}
