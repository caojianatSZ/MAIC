/* pages/index/index.wxss */

/* 渐变头部 */
.header-gradient {
  background: var(--primary-gradient);
  padding: 48rpx 32rpx 64rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.2);
}

.header-content {
  position: relative;
}

.greeting {
  margin-bottom: 16rpx;
}

.greeting-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.header-text .title {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--text-white);
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.header-text .subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 内容包装器 */
.content-wrapper {
  padding: 32rpx;
  margin-top: -32rpx;
}

/* 快速操作卡片 */
.quick-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.action-card {
  flex: 1;
  background: var(--card-background);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: var(--card-shadow);
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.action-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--primary-gradient);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.action-card.primary::before {
  opacity: 0.05;
}

.action-card:active {
  transform: scale(0.97);
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  position: relative;
  z-index: 1;
}

.action-card.primary .action-icon {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
}

.action-card.secondary .action-icon {
  background: var(--bg-secondary);
}

.icon-emoji {
  font-size: 48rpx;
}

.action-content {
  flex: 1;
  position: relative;
  z-index: 1;
}

.action-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.action-arrow {
  position: relative;
  z-index: 1;
}

.arrow-icon {
  font-size: 48rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}

/* 输入卡片 */
.input-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.input-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.char-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.modern-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  background: var(--bg-secondary);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.8;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.modern-textarea:focus {
  background: var(--bg-primary);
  border-color: var(--primary-light);
}

.textarea-placeholder {
  color: var(--text-tertiary);
}

/* 快捷操作按钮 */
.quick-actions-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.quick-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  background: var(--bg-secondary);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.quick-btn:active {
  background: var(--bg-tertiary);
}

.quick-btn-icon {
  font-size: 28rpx;
}

.quick-btn-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 提交按钮 */
.submit-wrapper {
  margin-top: 32rpx;
  margin-bottom: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 104rpx;
  background: var(--bg-tertiary);
  color: var(--text-tertiary);
  border-radius: 52rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
  transition: all 0.3s ease;
  box-shadow: none;
}

.submit-btn.active {
  background: var(--primary-gradient);
  color: var(--text-white);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.submit-btn:active {
  transform: scale(0.98);
}

.submit-btn-icon {
  font-size: 32rpx;
}

/* 功能介绍区 */
.features-section {
  margin-top: 48rpx;
}

.feature-list {
  margin-top: 24rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--card-background);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  border-radius: 16rpx;
  font-size: 36rpx;
  margin-right: 16rpx;
}

.feature-content {
  flex: 1;
}

.feature-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.feature-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 底部提示 */
.bottom-tip {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  padding: 32rpx;
}

.tip-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.tip-link {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
}
