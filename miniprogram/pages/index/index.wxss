/* pages/index/index.wxss - 优化版 */

/* 品牌头部 */
.brand-header {
  background: linear-gradient(135deg, #3B82F6 0%, #6366F1 100%);
  padding: 48rpx 32rpx 64rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(59, 130, 246, 0.2);
  position: relative;
  overflow: hidden;
}

.brand-header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.brand-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.brand-logo {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  backdrop-filter: blur(10rpx);
}

.logo-image {
  width: 64rpx;
  height: 64rpx;
}

.brand-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.brand-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: -0.5rpx;
  line-height: 1.2;
}

.brand-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
}

/* 内容包装器 */
.content-wrapper {
  padding: 32rpx;
  margin-top: -32rpx;
  position: relative;
  z-index: 10;
}

/* 快速操作卡片 */
.quick-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.action-card {
  flex: 1;
  background: var(--card-background);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: var(--card-shadow);
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.action-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #3B82F6 0%, #6366F1 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.action-card.primary::before {
  opacity: 0.05;
}

.action-card:active {
  transform: scale(0.97);
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  position: relative;
  z-index: 1;
}

.action-card.primary .action-icon {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(99, 102, 241, 0.1) 100%);
}

.action-card.secondary .action-icon {
  background: var(--bg-secondary);
}

.icon-svg {
  width: 48rpx;
  height: 48rpx;
}

.action-content {
  flex: 1;
  position: relative;
  z-index: 1;
}

.action-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.action-arrow {
  position: relative;
  z-index: 1;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.4;
}

/* 输入卡片 */
.input-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.input-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.char-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.modern-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  background: var(--bg-secondary);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.8;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.modern-textarea:focus {
  background: var(--bg-primary);
  border-color: #3B82F6;
}

.textarea-placeholder {
  color: var(--text-tertiary);
}

/* 快捷操作按钮 */
.quick-actions-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.quick-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  background: var(--bg-secondary);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.quick-btn:active {
  background: var(--bg-tertiary);
}

.quick-btn-icon {
  width: 28rpx;
  height: 28rpx;
}

.quick-btn-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 提交按钮 */
.submit-wrapper {
  margin-top: 32rpx;
  margin-bottom: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 104rpx;
  background: var(--bg-tertiary);
  color: var(--text-tertiary);
  border-radius: 52rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
  transition: all 0.3s ease;
  box-shadow: none;
}

.submit-btn.active {
  background: linear-gradient(135deg, #3B82F6 0%, #6366F1 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.4);
}

.submit-btn:active {
  transform: scale(0.98);
}

.submit-btn-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 功能介绍区 */
.features-section {
  margin-top: 48rpx;
}

.feature-list {
  margin-top: 24rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--card-background);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.feature-item:active {
  transform: scale(0.98);
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.08) 0%, rgba(99, 102, 241, 0.08) 100%);
  border-radius: 16rpx;
  margin-right: 16rpx;
}

.feature-icon-svg {
  width: 36rpx;
  height: 36rpx;
}

.feature-content {
  flex: 1;
}

.feature-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.feature-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 信任徽章 */
.trust-badges {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-top: 48rpx;
  padding: 32rpx 16rpx;
  background: var(--card-background);
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.badge-icon {
  width: 32rpx;
  height: 32rpx;
}

.badge-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* 底部提示 */
.bottom-tip {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  padding: 32rpx;
}

.tip-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.tip-link {
  font-size: 26rpx;
  color: #3B82F6;
  font-weight: 500;
}

/* 通用卡片 */
.card {
  background-color: var(--card-background);
  border-radius: var(--card-radius);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--card-shadow);
  transition: all 0.3s ease;
}

.card:active {
  transform: scale(0.98);
}

/* 徽章 */
.badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-primary {
  background-color: rgba(59, 130, 246, 0.1);
  color: #3B82F6;
}

/* 文本辅助类 */
.text-warning {
  color: #F59E0B;
}

/* hover 效果 */
.action-card-hover {
  transform: scale(0.98);
}
