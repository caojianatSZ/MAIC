<!--pages/index/index.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">作业辅导助手</text>
    <text class="subtitle">拍照或输入作业题目，获取智能讲解</text>
  </view>

  <!-- 拍照输入区域 -->
  <view class="card">
    <view class="card-title">
      <text class="title-text">拍照输入</text>
    </view>
    <view class="card-body">
      <button class="btn-camera" bindtap="onTakePhoto">
        <text class="btn-icon">📷</text>
        <text>拍照上传</text>
      </button>
      <text class="hint">支持拍照识别题目文字</text>
    </view>
  </view>

  <!-- 手动输入区域 -->
  <view class="card">
    <view class="card-title">
      <text class="title-text">手动输入</text>
    </view>
    <view class="card-body">
      <textarea
        class="textarea-input"
        placeholder="请输入作业题目内容..."
        value="{{questionText}}"
        bindinput="onInputChange"
        maxlength="1000"
        auto-height
      />
      <view class="char-count">{{questionText.length}}/1000</view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button
      class="btn-primary {{questionText.length > 0 ? 'active' : 'disabled'}}"
      bindtap="onSubmit"
      disabled="{{questionText.length === 0}}"
    >
      提交题目
    </button>
  </view>
</view>
