/* pages/review-list/review-list.wxss */

/* 容器 */
.container {
  min-height: 100vh;
  background: #f9fafb;
  padding-bottom: 32rpx;
}

/* 页面头部 */
.page-header {
  padding: 32rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #6366f1 100%);
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 科目筛选 */
.subject-filter {
  padding: 24rpx 32rpx 16rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  gap: 16rpx;
}

.filter-item {
  display: inline-flex;
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  transition: all 0.2s;
}

.filter-item.active {
  background: linear-gradient(135deg, #3b82f6 0%, #6366f1 100%);
}

.filter-text {
  font-size: 28rpx;
  color: #666;
}

.filter-item.active .filter-text {
  color: #fff;
  font-weight: 600;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #6366f1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 错题列表 */
.questions-list {
  padding: 0 32rpx;
}

.question-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.subject-badge {
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.subject-badge.subject-math {
  background: #dbeafe;
}

.subject-badge.subject-math .subject-text {
  color: #1d4ed8;
}

.subject-badge.subject-physics {
  background: #fce7f3;
}

.subject-badge.subject-physics .subject-text {
  color: #be185d;
}

.subject-badge.subject-chemistry {
  background: #d1fae5;
}

.subject-badge.subject-chemistry .subject-text {
  color: #047857;
}

.subject-badge.subject-english {
  background: #fef3c7;
}

.subject-badge.subject-english .subject-text {
  color: #b45309;
}

.subject-badge.subject-chinese {
  background: #e0e7ff;
}

.subject-badge.subject-chinese .subject-text {
  color: #4338ca;
}

/* 置信度信息 */
.confidence-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.confidence-label {
  font-size: 24rpx;
  color: #666;
}

.confidence-bar-wrapper {
  width: 80rpx;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.confidence-bar {
  height: 100%;
  transition: all 0.3s;
}

.confidence-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  min-width: 60rpx;
  text-align: right;
}

/* 题目内容 */
.question-content {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.question-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* 答案区域 */
.answer-section {
  display: flex;
  flex-direction: column;
  padding: 16rpx 20rpx;
  background: #fef2f2;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.answer-section.correct {
  background: #f0fdf4;
}

.answer-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.label-icon {
  font-size: 24rpx;
}

.label-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
}

.answer-value {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
  padding-left: 32rpx;
}

/* 低置信度提示 */
.low-confidence-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: #fef3c7;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.tip-icon {
  font-size: 24rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #b45309;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.review-time {
  font-size: 24rpx;
  color: #999;
}

.review-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #6366f1 100%);
  border-radius: 20rpx;
}

.btn-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.btn-arrow {
  font-size: 32rpx;
  color: #fff;
  font-weight: 300;
}

/* 底部提示 */
.footer-tip {
  display: flex;
  justify-content: center;
  padding: 32rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
}
